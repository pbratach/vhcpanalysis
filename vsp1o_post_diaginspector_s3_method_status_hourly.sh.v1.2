#!/bin/bash
# Author: Paul Bratach with help from CoPilot
# Version 1.0
#   Used awk
#   Comma formatting inside awk
#
# Version 1.1
#   Use gawk
#   Add AvgSize and improve output headers and column widths
#   Add version number and start, end and duration times for script
#   Add LC_ALL and LC_NUMERIC parameters
#
# Version 1.2
#   Check for existence of all-s3-gateway-istio-proxy.txt-no-downstream_remote_disconnect.txt
#   If exists, ask user if they want to use that file
#     If yes, use that file
#     If no, generate a new file
#   Else
#     generate a new file
#
export LC_ALL="en_US.UTF-8"
export LC_NUMERIC="en_US.UTF-8"

# Display the version of the script
echo " "
echo "Script version 1.2.0 (01/23/2026)"

create_file() {
	# Combine and Count the number of S3 calls in s3-gateway*istio-proxy logs
	echo -e "\033[0;32mCombining and counting the total number of S3 calls in istio s3-gateway istio-proxy logs into\033[0m all-s3-gateway-istio-proxy.txt"
	for i in `find . -name "*s3-gateway*istio-proxy*" -print`; do cat $i >> all-s3-gateway-istio-proxy.txt; done
	echo -e "\033[0;32mTotal number of S3 calls in s3-gateway istio-proxy logs:\033[0m `wc -l  all-s3-gateway-istio-proxy.txt | awk '{print $1}' | sed ':a;s/\B[0-9]\{3\}\>/,&/;ta'`"

	# Count the number of downstream_remote_disconnect errors in istio s3 logs
	echo -e "\033[0;32mTotal number of downstream_remote_disconnect errors in S3 calls in s3-gateway istio-proxy logs:\033[0m `grep downstream_remote_disconnect all-s3-gateway-istio-proxy.txt | wc -l | sed ':a;s/\B[0-9]\{3\}\>/,&/;ta'`"
	
	# Remove the downstream_remote_disconnect errors in istio s3 logs
	echo -e "\033[0;32mCopying S3 calls in s3-gateway istio-proxy logs without downstream_remote_disconnect errors into\033[0m all-s3-gateway-istio-proxy.txt-no-downstream_remote_disconnect.txt"
	grep -v downstream_remote_disconnect all-s3-gateway-istio-proxy.txt > all-s3-gateway-istio-proxy.txt-no-downstream_remote_disconnect.txt

	# Count the number of S3 calls ignoring downstream_remote_disconnect errors in istio s3 logs
	echo -e "\033[0;32mTotal number of S3 calls excluding downstream_remote_disconnect errors in s3-gateway istio-proxy logs:\033[0m `wc -l all-s3-gateway-istio-proxy.txt-no-downstream_remote_disconnect.txt | awk '{print $1}' | sed ':a;s/\B[0-9]\{3\}\>/,&/;ta'`"

        return 0
}

# Check if all-s3-gateway-istio-proxy.txt-no-downstream_remote_disconnect.txt exists"
TARGET_FILE="all-s3-gateway-istio-proxy.txt"

# Check if the file exists in the current directory
if [[ -f "$TARGET_FILE" ]]; then
    # Get last modified date/time
    MOD_TIME=$(stat -c "%y" "$TARGET_FILE")

    echo " "
    echo "File found: $TARGET_FILE"
    echo "Last modified: $MOD_TIME"
    echo
    read -p "Do you want to use this file or exit? (y/n/x): " ANSWER

    case "$ANSWER" in
        y|Y)
            echo "Using existing file: $TARGET_FILE"
            ;;
        n|N)
            echo "Generating a new file..."
            # Add your file‑generation logic here
            create_file
            ;;
        x|X)
            echo "Exiting."
            exit 1
            ;;
        *)
            echo "Invalid response. Exiting."
            exit 1
            ;;
    esac

else
    echo "The file '$TARGET_FILE' does not exist."
    echo "The script will now generate the file."
    # Add your file‑generation logic here
    create_file
fi


# Record the start time using the %s format (seconds since the epoch)
START_TIME=$(date +%s)
echo "Script started at: $(date)"
echo " "

echo "Calculating Hour, Method, Status, Count, TotalSize Bytes, AvgSize Bytes, MinTime (msec), MaxTime (msec), AvgTime (msec)"
echo "`wc -l all-s3-gateway-istio-proxy.txt-no-downstream_remote_disconnect.txt | awk '{print $1}'` records to process, this may take some time"
echo " "

gawk '

###############################################################################
# Utility Functions
###############################################################################

# Format numbers with commas, but only if integer part >= 100
function comma(num,    s, neg, dot, whole, frac) {
    num = num ""

    # Find decimal point
    dot = index(num, ".")
    if (dot > 0) {
        whole = substr(num, 1, dot - 1)
        frac  = substr(num, dot)
    } else {
        whole = num
        frac  = ""
    }

    # No commas for small numbers
    if (whole + 0 < 100) return whole frac

    # Handle negative
    if (substr(whole, 1, 1) == "-") {
        neg = 1
        whole = substr(whole, 2)
    }

    s = ""
    while (length(whole) > 3) {
        s = "," substr(whole, length(whole) - 2) s
        whole = substr(whole, 1, length(whole) - 3)
    }
    s = whole s

    if (neg) s = "-" s
    return s frac
}

# Safe average
function avg(total, count) {
    return (count > 0 ? total / count : 0)
}

###############################################################################
# Main Parsing Loop
###############################################################################

{
    if (NF < 12) next
    if (substr($1,1,1) != "[") next

    ts = substr($1, 2)
    split(ts, t1, "T")
    split(t1[2], t2, ":")
    hour = t1[1] "T" t2[1]

    method = $2
    gsub(/"/, "", method)
    if (method == "-") next

    status = $5
    if (status + 0 != status) next

    if (method == "PUT")
        size = $10
    else
        size = $11
    if (size + 0 != size) next

    tval = $12
    if (tval + 0 != tval) next

    key = hour " " method " " status

    count[key]++
    total_size[key] += size
    total_time[key] += tval

    if (!(key in min_time) || tval < min_time[key]) min_time[key] = tval
    if (!(key in max_time) || tval > max_time[key]) max_time[key] = tval
}

###############################################################################
# Final Output
###############################################################################

END {
    printf "%-15s %-8s %-6s %-12s %-19s %-19s %-8s %-12s %-12s\n",
           "Hour", "Method", "Code", "Count",
	   "TotalSize", "AvgSize", "MinTime", "MaxTime", "AvgTime(msec)"

    for (k in count) keys[++n] = k
    asort(keys)

    for (i = 1; i <= n; i++) {
        k = keys[i]
        split(k, p, " ")

        hour    = p[1]
        method  = p[2]
        code    = p[3]

        c       = count[k]
        total   = total_size[k]
        avgsize = avg(total, c)

        minv    = min_time[k]
        maxv    = max_time[k]
        avgtime = avg(total_time[k], c)

        printf "%-15s %-8s %-6s %-12d %-19s %-19s %-8d %-12s %-12s\n",
               hour,
               method,
               code,
               c,
               comma(total),
               comma(sprintf("%.2f", avgsize)),
               minv,
               comma(maxv),
               comma(sprintf("%.2f", avgtime))
    }
}
' all-s3-gateway-istio-proxy.txt-no-downstream_remote_disconnect.txt

# Calculate the total duration in seconds
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

# Calculate hours, minutes, and seconds from the total duration
HOURS=$((DURATION / 3600))
MINUTES=$(( (DURATION % 3600) / 60 ))
SECONDS=$((DURATION % 60))

# Display the elapsed time
echo " "
echo "--------------------------------------------------"
echo "Script finished at $(date)"
echo "Total runtime: ${HOURS}h ${MINUTES}m ${SECONDS}s"
echo "--------------------------------------------------"

unset LC_ALL
unset LC_NUMERIC

